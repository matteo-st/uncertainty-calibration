@misc{bihani_calibration_2023,
	title = {Calibration {Error} {Estimation} {Using} {Fuzzy} {Binning}},
	url = {http://arxiv.org/abs/2305.00543},
	doi = {10.48550/arXiv.2305.00543},
	abstract = {Neural network-based decisions tend to be overconfident, where their raw outcome probabilities do not align with the true decision probabilities. Calibration of neural networks is an essential step towards more reliable deep learning frameworks. Prior metrics of calibration error primarily utilize crisp bin membership-based measures. This exacerbates skew in model probabilities and portrays an incomplete picture of calibration error. In this work, we propose a Fuzzy Calibration Error metric (FCE) that utilizes a fuzzy binning approach to calculate calibration error. This approach alleviates the impact of probability skew and provides a tighter estimate while measuring calibration error. We compare our metric with ECE across different data populations and class memberships. Our results show that FCE offers better calibration error estimation, especially in multi-class settings, alleviating the effects of skew in model confidence scores on calibration error estimation. We make our code and supplementary materials available at: https://github.com/bihani-g/fce},
	urldate = {2026-01-15},
	publisher = {arXiv},
	author = {Bihani, Geetanjali and Rayz, Julia Taylor},
	month = may,
	year = {2023},
	note = {arXiv:2305.00543 [cs]},
	keywords = {Computer Science - Machine Learning, Computer Science - Artificial Intelligence, Computer Science - Neural and Evolutionary Computing},
	file = {Full Text PDF:C\:\\Users\\matte\\Zotero\\storage\\HDZUYFHI\\Bihani and Rayz - 2023 - Calibration Error Estimation Using Fuzzy Binning.pdf:application/pdf;Snapshot:C\:\\Users\\matte\\Zotero\\storage\\UHXTCJCA\\2305.html:text/html},
}

@misc{berta_classifier_2023,
	title = {Classifier {Calibration} with {ROC}-{Regularized} {Isotonic} {Regression}},
	url = {http://arxiv.org/abs/2311.12436},
	doi = {10.48550/arXiv.2311.12436},
	abstract = {Calibration of machine learning classifiers is necessary to obtain reliable and interpretable predictions, bridging the gap between model confidence and actual probabilities. One prominent technique, isotonic regression (IR), aims at calibrating binary classifiers by minimizing the cross entropy on a calibration set via monotone transformations. IR acts as an adaptive binning procedure, which allows achieving a calibration error of zero, but leaves open the issue of the effect on performance. In this paper, we first prove that IR preserves the convex hull of the ROC curve -- an essential performance metric for binary classifiers. This ensures that a classifier is calibrated while controlling for overfitting of the calibration set. We then present a novel generalization of isotonic regression to accommodate classifiers with K classes. Our method constructs a multidimensional adaptive binning scheme on the probability simplex, again achieving a multi-class calibration error equal to zero. We regularize this algorithm by imposing a form of monotony that preserves the K-dimensional ROC surface of the classifier. We show empirically that this general monotony criterion is effective in striking a balance between reducing cross entropy loss and avoiding overfitting of the calibration set.},
	urldate = {2026-01-17},
	publisher = {arXiv},
	author = {Berta, Eugene and Bach, Francis and Jordan, Michael},
	month = nov,
	year = {2023},
	note = {arXiv:2311.12436 [cs]},
	keywords = {Computer Science - Machine Learning},
	file = {Full Text PDF:C\:\\Users\\matte\\Zotero\\storage\\MENPME7V\\Berta et al. - 2023 - Classifier Calibration with ROC-Regularized Isotonic Regression.pdf:application/pdf;Snapshot:C\:\\Users\\matte\\Zotero\\storage\\T6P2A4YG\\2311.html:text/html},
}

